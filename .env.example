# Meta Marketing API
ACCESS_TOKEN=
AD_ACCOUNT_ID=
PAGE_ID=

# OpenAI (Whisper transcription)
OPENAI_API_KEY=

# Anthropic (ad copy generation)
ANTHROPIC_API_KEY=

# RapidAPI (TikTok video download)
RAPIDAPI_KEY=
# Optional override; default is tiktok-video-no-watermark2.p.rapidapi.com
# RAPIDAPI_TIKTOK_HOST=

# Login credentials for the deployed app — set BOTH on Railway to require login.
# Leave unset locally to skip auth in dev.
APP_USERNAME=
APP_PASSWORD=

# Optional: signs the session cookie. If unset, a random key is generated each
# process start (sessions invalidate on restart). Set in Railway for stable sessions.
SECRET_KEY=
